# Copy to .env and fill in to enable REAL Zerodha trading (optional).
# Leave unset to run in safe DEMO mode (no login, no real money).
# Get these from your own Kite Connect app at https://developers.kite.trade
KITE_API_KEY=
KITE_API_SECRET=

# Optional: rupee safety cap per order (default 5000)
# MAX_ORDER_VALUE=5000

# Optional: port (default 4173)
# PORT=4173
